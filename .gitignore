# ── Live data — NEVER commit these ───────────────────────────────────────────
# The bot writes to restocker.db constantly. Committing it means every push carries
# a stale snapshot, and every server pull fights (or overwrites) the live database.
# It stays on disk; it just must not travel through git.
restocker.db
restocker.db-journal
restocker.db-wal
restocker.db-shm
*.db
*.db-journal
*.db-wal
*.db-shm

# Automatic DB backups (see db_backup_loop) — local to each machine.
backups/

# Runtime YAML state the bot writes (the DB is the source of truth; these are its
# write-only mirrors/fallbacks and would cause the same pull conflicts if tracked).
data/state/
data/csn_history/
data/exports/

# Secrets / environment
.env
.env.*
!.env.example

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

# Editor / OS junk
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
